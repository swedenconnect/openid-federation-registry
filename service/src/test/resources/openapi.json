  "components": {
    "schemas": {
      "TrustmarkSubject": {
        "type": "object",
        "properties": {
          "trustmarksubjectId": {
            "type": "string",
            "format": "uuid",
            "description": "Trustmark subject ID",
            "readOnly": true
          },
          "trustmarkId": {
            "type": "string",
            "description": "Trust mark identifier (entity id)"
          },
          "subject": {
            "type": "string",
            "description": "Subject entity id"
          },
          "revoked": {
            "type": "boolean",
            "description": "If the trust mark is revoked for this subject"
          },
          "granted": {
            "type": "string",
            "format": "date-time",
            "description": "Granted time (ISO-8601, e.g. 2025-01-01T00:00:00)"
          },
          "expires": {
            "type": "string",
            "format": "date-time",
            "description": "Expires time (ISO-8601, e.g. 2025-01-01T00:00:00)"
          }
        }
      },
      "Policy": {
        "type": "object",
        "properties": {
          "policyId": {
            "type": "string",
            "format": "uuid",
            "description": "Policy ID",
            "readOnly": true
          },
          "name": {
            "type": "string",
            "description": "Policy name",
            "example": "Default OIDC RP policy"
          },
          "policy": {
            "type": "object",
            "additionalProperties": {},
            "description": "JSON policy document"
          }
        }
      },
      "Trustmark": {
        "type": "object",
        "properties": {
          "trustmarkId": {
            "type": "string",
            "format": "uuid",
            "description": "Trustmark ID",
            "readOnly": true
          },
          "trustmarkissuerId": {
            "type": "string",
            "description": "Trust mark issuer entity identifier"
          },
          "trustMarkEntityId": {
            "type": "string",
            "description": "Trust mark entity identifier"
          },
          "logoUri": {
            "type": "string",
            "description": "Logo URI"
          },
          "refUri": {
            "type": "string",
            "description": "Reference URI"
          },
          "delegation": {
            "type": "string",
            "description": "Delegation JWT"
          }
        }
      },
      "TrustAnchor": {
        "type": "object",
        "properties": {
          "moduleId": {
            "type": "string",
            "format": "uuid",
            "description": "Module ID",
            "readOnly": true
          },
          "entityId": {
            "type": "string",
            "format": "uuid",
            "description": "Entity identifier that this trust anchor belongs to. "
          },
          "active": {
            "type": "boolean",
            "description": "If this trust anchor is active"
          },
          "trustMarkIssuers": {
            "type": "array",
            "description": "Entity identifiers for trust mark issuers",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "Resolver": {
        "type": "object",
        "properties": {
          "moduleId": {
            "type": "string",
            "format": "uuid",
            "description": "Module ID",
            "readOnly": true
          },
          "entityId": {
            "type": "string",
            "format": "uuid",
            "description": "Entity identifier that this module belongs to"
          },
          "active": {
            "type": "boolean",
            "description": "If this resolver instance is active"
          },
          "resolveResponseDuration": {
            "type": "string",
            "description": "Response duration (ISO-8601 duration, e.g. PT1H)"
          },
          "trustAnchor": {
            "type": "string",
            "description": "Trust anchor entityId that this resolver is connected to"
          },
          "trustedKeys": {
            "type": "string",
            "description": "Trusted keys as JWKS JSON of the trust anchor"
          },
          "stepRetryDuration": {
            "type": "string",
            "description": "Step retry duration (ISO-8601 duration, e.g. PT1H)"
          }
        }
      },
      "SubordinateEntity": {
        "type": "object",
        "properties": {
          "entityId": {
            "type": "string",
            "format": "uuid",
            "description": "Entity ID",
            "readOnly": true
          },
          "subject": {
            "type": "string",
            "description": "Subject (entity identifier)"
          },
          "issuer": {
            "type": "string",
            "description": "Issuer (entity identifier)"
          },
          "jwks": {
            "type": "string",
            "description": "JWKS as JSON string"
          },
          "policyId": {
            "type": "string",
            "format": "uuid",
            "description": "Pointer to the policy used for this subordinate"
          }
        }
      },
      "HostedEntity": {
        "type": "object",
        "properties": {
          "entityId": {
            "type": "string",
            "format": "uuid",
            "description": "Entity ID",
            "readOnly": true
          },
          "subject": {
            "type": "string",
            "description": "Subject (entity identifier)"
          },
          "issuer": {
            "type": "string",
            "description": "Issuer (entity identifier)"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": {},
            "description": "Metadata for hosted entity"
          }
        }
      },
      "FederationEntity": {
        "type": "object",
        "properties": {
          "entityId": {
            "type": "string",
            "format": "uuid",
            "description": "Entity ID",
            "readOnly": true
          },
          "subject": {
            "type": "string",
            "description": "Subject (entity identifier)",
            "example": "https://rp.example.se"
          },
          "issuer": {
            "type": "string",
            "description": "Issuer (entity identifier)",
            "example": "https://ta.example.se"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": {},
            "description": "Federation entity metadata",
            "example": {
              "federation_entity": {}
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "description": "JWT token obtained from authentication endpoint",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "selectedOrgNumber": {
        "type": "apiKey",
        "description": "Organization number to use for the request. Enter your organization number here.",
        "name": "selected-org-number",
        "in": "header"
      }
    }
  }
}